<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Button</title>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>
<body>
    <!-- jumbotron -->
     <div class="p-5 m-5 bg-light rounded-5 border container-fluid">aaaaaaaaaaaaaaaaaaaaaaaaaaaaaabbbbbbbbbbbbbbbbbbbbbbbcccccccccccccccccccccdddddddddddddddddddddeeeeeeeeeeeeeeeeeeefffffffffffffffff</div>



    <!-- button -->
    <div class="text-center mt-5">
        <button type="button" class="btn btn-danger">Delete</button>
    </div>

    <!-- badge -->
    <span class="badge badge-primary" style="width: 50px;height: 105px;">hi</span>   <br>
    <span class="badge badge-secondary text-dark bg-warning">hello</span>  

    <!-- progress bar -->
    <div class="progress" mb-3>
        <div class="progress-bar bg-success" mb-5 style="width: 25%;height: 30px;" aria-valuenow="25" >25%</div>
    </div>    
    <!-- animated progress bar -->
     <div class="progress">
        <div class="progress-bar progress-bar animated progress-bar stripped bg-light" mb-5 style="width: 75%;height: 30px;" aria-valuenow="75" >75%</div>
    </div>
  
<hr>

    <!-- spinner -->
    <div class="spinner-border text-primary" role="status">
        <span class="visually hidden">Loading...</span>
    </div>

    <!-- cards -->
    <div class="card" style="width: 18rem;">
        <img src="https://www.codingal.com/student/dashboard/projects/">
        <div class="card-body">
            <h5 class="card-title">Card Title</h5>
            <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
        </div>
    </div>

    <!-- navigation bar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <a class="navbar-brand">Navbar</a>
            <span class="navbar-hamburger-icon"></span>
        
        <div class="collapse navbar-collapse" id="Nav">
            <ul class="navbar-nav">
                <li class="nav-item active">object </li>
                   
                <li class="nav-item">Features </li>
               
                <li class="nav-item">Pricing</li>
                    
                
            </ul>
        </div>

<hr>

  <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.7/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>

    
</body>
</html>